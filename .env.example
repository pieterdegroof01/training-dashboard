# Strava - vul in vanuit jouw Strava API instellingen
STRAVA_CLIENT_ID=235226
STRAVA_CLIENT_SECRET=jouw_client_secret_hier
STRAVA_REFRESH_TOKEN=jouw_refresh_token_hier

# Hevy - vind je in de Hevy app onder Instellingen > API
HEVY_API_KEY=jouw_hevy_api_key_hier

# Anthropic - vind je op console.anthropic.com onder API Keys
ANTHROPIC_API_KEY=jouw_anthropic_api_key_hier

# Poort waarop de server draait (niet aanpassen)
PORT=3000
